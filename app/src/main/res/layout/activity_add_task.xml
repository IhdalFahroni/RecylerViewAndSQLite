<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#fdf8fd">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add New Task"
        android:textColor="#24389c"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Task Title"
        android:textColor="#454652"
        android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/etTaskTitle"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="e.g., Prepare Q3 Report"
        android:paddingHorizontal="16dp"
        android:background="#f1ecf2"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Task Description"
        android:textColor="#454652"
        android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/etTaskDesc"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:hint="Provide details about the task..."
        android:gravity="top|start"
        android:padding="16dp"
        android:background="#f1ecf2"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Priority Selection"
        android:textColor="#454652"
        android:layout_marginBottom="4dp"/>
    <Spinner
        android:id="@+id/spinnerPriority"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#f1ecf2"
        android:entries="@array/priority_options"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Save Task"
        android:textSize="16sp"
        android:backgroundTint="#24389c"
        android:textColor="@android:color/white"/>

</LinearLayout>